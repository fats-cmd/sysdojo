# sysdojo environment variables — copy to .env (never commit real secrets).
# The API and `npm run db:migrate` read the repo-root .env automatically;
# variables exported in your shell take precedence.

# ---- apps/api ----
# Port the API listens on.
PORT=3000
# Secret used to sign access tokens. REQUIRED in production; the dev default
# is only for local development.
JWT_SECRET=dev-secret-change-me
# Override where YAML question content is loaded from (defaults to ./content).
# CONTENT_DIR=/absolute/path/to/content
# Postgres connection for persistent storage (docker compose up -d db).
# Leave commented for the in-memory dev store (data resets on API restart).
# The database name must match POSTGRES_DB in docker-compose.yml.
# DATABASE_URL=postgresql://sysdojo:sysdojo@localhost:5432/sysdojo
# Separate database used by the PrismaStore contract tests (optional).
# TEST_DATABASE_URL=postgresql://sysdojo:sysdojo@localhost:5432/sysdojo_test
# Browser origin allowed by CORS (only matters for Expo web). Defaults to *.
# CORS_ORIGIN=http://localhost:8081
# Supabase project JWT secret (Dashboard → Settings → API). Setting this
# switches /v1/auth/login to verifying real Supabase access tokens and
# disables the no-credential /v1/auth/dev endpoint.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Keep dev login available even with Supabase configured (local testing only).
# ALLOW_DEV_LOGIN=1

# ---- apps/mobile ----
# Where the app finds the API. Usually leave this unset: the app resolves it
# automatically (Metro's LAN IP on physical devices, 10.0.2.2 on Android
# emulators, localhost elsewhere). Set it only when the API runs on another
# machine or port. No trailing slash.
# EXPO_PUBLIC_API_URL=http://192.168.1.20:3000
