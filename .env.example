# sysdojo environment variables — copy to .env (never commit real secrets).

# ---- apps/api ----
# Port the API listens on.
PORT=3000
# Secret used to sign access tokens. REQUIRED in production; the dev default
# is only for local development.
JWT_SECRET=dev-secret-change-me
# Override where YAML question content is loaded from (defaults to ./content).
# CONTENT_DIR=/absolute/path/to/content

# ---- apps/mobile ----
# Where the app finds the API. Defaults to http://localhost:3000
# (http://10.0.2.2:3000 on Android emulators). Set this to your machine's LAN
# IP when testing on a physical device, e.g. http://192.168.1.20:3000
# EXPO_PUBLIC_API_URL=http://localhost:3000
