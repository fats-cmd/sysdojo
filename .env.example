# sysdojo environment variables — copy to .env (never commit real secrets).

# ---- apps/api ----
# Port the API listens on.
PORT=3000
# Secret used to sign access tokens. REQUIRED in production; the dev default
# is only for local development.
JWT_SECRET=dev-secret-change-me
# Override where YAML question content is loaded from (defaults to ./content).
# CONTENT_DIR=/absolute/path/to/content
# Postgres connection for persistent storage (docker compose up -d db).
# Unset = in-memory dev store, data resets on API restart.
# Required in the environment (not just .env) for `prisma migrate` commands.
DATABASE_URL=postgresql://sysdojo:sysdojo@localhost:5432/sysdojos
# The API and `npm run db:migrate` both read this .env automatically
# (shell environment variables take precedence).
# DATABASE_URL=postgresql://sysdojo:sysdojo@localhost:5432/sysdojo
# Separate database used by the PrismaStore contract tests (optional).
# TEST_DATABASE_URL=postgresql://sysdojo:sysdojo@localhost:5432/sysdojo_test

# ---- apps/mobile ----
# Where the app finds the API. Defaults to http://localhost:3000
# (http://10.0.2.2:3000 on Android emulators). Set this to your machine's LAN
# IP when testing on a physical device, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://192.168.1.7:3000/
